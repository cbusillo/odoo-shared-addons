{
  "defaultBranch": "main",
  "projectType": "odoo-shared-addon-collection",
  "docs": {
    "index": "README.md",
    "routingNotes": [
      "This repo does not own a local @docs tree; addon AGENTS guidance must stay local or explicitly name the owning external workspace."
    ],
    "addonGuides": [
      "authentik_sso/AGENTS.md",
      "discuss_record_links/AGENTS.md",
      "environment_banner/AGENTS.md",
      "environment_banner/README.md",
      "external_ids/AGENTS.md",
      "hr_employee_name_extended/AGENTS.md",
      "hr_employee_name_extended/README.md",
      "launchplane_settings/AGENTS.md",
      "notification_permission_patch/AGENTS.md",
      "test_support/AGENTS.md",
      "transaction_utilities/AGENTS.md"
    ]
  },
  "qualityGate": {
    "test": {
      "addonOdoo": "odoo-bin --test-enable --stop-after-init -i <addon>",
      "validatedThrough": ["odoo-tenant-cm", "odoo-tenant-opw"]
    },
    "inspection": {
      "tool": "jetbrains",
      "ide": "PyCharm",
      "scopePreference": ["changed_files", "directory", "whole_project"]
    },
    "docsRequiredWhen": [
      "behavior changes",
      "api changes",
      "config changes",
      "operations changes",
      "ownership boundaries change",
      "addon behavior changes",
      "addon dependency changes",
      "security/access-rule changes",
      "tenant validation routing changes"
    ]
  },
  "importantWorkflows": [],
  "qaLabels": [],
  "deployLabels": [],
  "healthUrls": [],
  "relatedRepos": [
    "odoo-devkit",
    "odoo-tenant-cm",
    "odoo-tenant-opw",
    "launchplane"
  ],
  "validatedThrough": ["odoo-tenant-cm", "odoo-tenant-opw"],
  "githubSignals": {
    "postMerge": {
      "waitForActions": true,
      "checkSecurityAndQuality": true
    },
    "capabilities": {
      "codeScanning": "available",
      "secretScanning": "available",
      "dependabotAlerts": "available",
      "securityAdvisories": "available"
    },
    "refreshWhen": [
      "repo visibility changes",
      "GitHub plan changes",
      "security settings change",
      "token permissions change"
    ]
  },
  "cleanup": {
    "deleteMergedLocalBranches": true,
    "removeMergedCleanWorktrees": true
  },
  "metadataFreshness": {
    "updateWhen": [
      "docs routing changes",
      "validation gates change",
      "primary commands change",
      "important workflows change",
      "repo relationship changes",
      "validated-through repos change",
      "cleanup policy changes",
      "ownership boundaries change",
      "addon list changes",
      "addon dependency changes",
      "tenant validation routing changes"
    ]
  }
}
